{
  "name": "strat-portfolio-builder",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-command.mjs generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "node scripts/prisma-command.mjs generate",
    "prisma:migrate": "node scripts/prisma-command.mjs migrate dev",
    "prisma:db:push": "node scripts/prisma-command.mjs db push --skip-generate",
    "prisma:deploy:bootstrap": "npm run prisma:db:push && npm run prisma:seed",
    "prisma:seed": "tsx prisma/seed.ts",
    "migrate:legacy-execution": "tsx scripts/migrate-legacy-execution.ts",
    "google:auth": "node --env-file=.env scripts/google-auth-bootstrap.mjs",
    "netlify:build": "npm run prisma:deploy:bootstrap && npm run build",
    "railway:web:start": "next start",
    "railway:web:predeploy": "npm run prisma:deploy:bootstrap",
    "railway:cron:start": "node scripts/run-railway-cron.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.4.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.5.9",
    "googleapis": "^171.4.0",
    "lightweight-charts": "^5.0.6",
    "lucide-react": "^0.475.0",
    "next": "^15.1.7",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.20.1",
    "eslint-config-next": "^15.1.7",
    "postcss": "^8.5.3",
    "prettier": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "6.4.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run vercel:build",
  "crons": [
    {
      "path": "/api/cron/nightly",
      "schedule": "15 2 * * *"
    },
    {
      "path": "/api/cron/daily-brief",
      "schedule": "*/15 * * * *"
    }
  ]
}
